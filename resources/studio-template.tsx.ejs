const fs = process.mainModule.require('fs');
const path = process.mainModule.require('path');

function normalizePath(inputPath) {
  return String(inputPath).replace(/\\/g, '/').replace(/^\.\//, '');
}

function splitPath(inputPath) {
  return normalizePath(inputPath).split('/').filter(Boolean);
}

function toRelativeImport(fromDir, toPath) {
  const fromParts = splitPath(fromDir);
  const toParts = splitPath(toPath);
  while (fromParts.length > 0 && toParts.length > 0 && fromParts[0] === toParts[0]) {
    fromParts.shift();
    toParts.shift();
  }
  const segments = [...fromParts.map(() => '..'), ...toParts];
  const result = segments.join('/');
  return result.startsWith('.') ? result : `./${result}`;
}

function buildLibImportPath() {
  const libImportPath = config.apiNext?.libImportPath;
  if (!libImportPath || !libImportPath.startsWith('.')) {
    return libImportPath || '@airent/api-next';
  }
  return toRelativeImport(config.generatedPath, libImportPath);
}

function getTypeScriptFileNames(inputPath) {
  const absolutePath = path.join(process.cwd(), inputPath);
  if (!fs.existsSync(absolutePath)) {
    return [];
  }
  return fs.readdirSync(absolutePath)
    .filter((name) => name.endsWith('.ts'))
    .map((name) => name.replace(/\.ts$/, ''))
    .sort((a, b) => a.localeCompare(b));
}

function buildImportPath(inputPath, name) {
  return toRelativeImport(config.generatedPath, `${inputPath}/${name}`);
}

function toKebabPlural(inputPath) {
  return inputPath
    .replace(/([a-z0-9])([A-Z])/g, '$1-$2')
    .toLowerCase();
}

