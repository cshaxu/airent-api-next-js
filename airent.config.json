  "api": {
    "typesPath": "test-project/src/api-types",
    "server": {
      "servicePath": "test-project/src/services",
      "dispatcherConfigImportPath": "./test-project/src/framework"
    },
    "client": {
      "baseUrlImportPath": "./test-project/src/config"
    }
  },
  "apiNext": {
    "libImportPath": "./src/index",
    "appPath": "test-project/src/app",
    "airentApiPath": "/api/airent",
    "handlerConfigImportPath": "./test-project/src/framework",
    "cronSourcePath": "test-project/src/cron",
    "cronApiPath": "/api/cron",
    "cronHandlerOptions": "{}",
    "debugSourcePath": "test-project/src/debug",
    "debugApiPath": "/api/debug",
    "debugHandlerOptions": "",
    "webhookSourcePath": "test-project/src/webhooks",
    "webhookApiPath": "/api/webhooks",
    "templates": [
      {
        "name": "./test-project/plugins/file-template.ts.ejs",
        "inputType": "files",
        "outputType": "file",
        "inputPath": "test-project/src",
        "outputPath": "test-project/src/generated/file-names.ts"
      },
      {
        "name": "./test-project/plugins/files-template.ts.ejs",
        "inputType": "folders",
        "outputType": "files",
        "inputPath": "test-project/src",
        "outputPath": "test-project/src/generated/folder-names"
      }
    ]
  }
